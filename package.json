    "pdfkit": "^0.18.0",
    "playwright-core": "^1.58.2",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "semver": "^7.7.3",
    "terminal-image": "^4.1.0",
    "tesseract.js": "^7.0.0",
    "tiktoken": "^1.0.22",
