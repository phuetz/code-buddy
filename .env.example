# Grok CLI Environment Variables
# Copy this file to .env and fill in your values
# Get your API key from https://x.ai

# API Key (required)
GROK_API_KEY=your_grok_api_key_here

# Alternative API key name (for compatibility)
# XAI_API_KEY=your_api_key_here

# Base URL (optional)
# Default: https://api.x.ai/v1
# Use custom endpoints for proxies or different providers
# GROK_BASE_URL=https://api.x.ai/v1

# Default Model (optional)
# Options: grok-beta, grok-2-1212, grok-3-latest, grok-4-latest
# Default: grok-4-latest
# GROK_MODEL=grok-4-latest

# Performance Monitoring (optional)
# Enable performance tracking
# GROK_PERFORMANCE_MONITORING=false

# Debug Mode (optional)
# Enable debug logging
# GROK_DEBUG=false

# Serper API Key (optional)
# Get your API key from https://serper.dev
# Enables Google Search for web queries
# SERPER_API_KEY=your_serper_api_key_here

# Google/Gemini API Key (optional)
# Get your API key from https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Google OAuth Credentials for Gemini First-Party Login
# GEMINI_OAUTH_CLIENT_ID=your_oauth_client_id_here
# GEMINI_OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Brave Search API Key (optional)
# Enables Brave MCP web search (highest priority in fallback chain)
# Get your key from https://brave.com/search/api/
# BRAVE_API_KEY=your_brave_api_key_here

# Exa Neural Search API Key (optional)
# Enables Exa MCP semantic search
# Get your key from https://exa.ai
# EXA_API_KEY=your_exa_api_key_here

# Perplexity AI Search API Key (optional)
# Enables AI-synthesized web search with citations
# Supports direct Perplexity key (pplx-...) or OpenRouter key (sk-or-...)
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# PERPLEXITY_MODEL=perplexity/sonar-pro

# Cache Trace (optional, debug)
# Logs every stage of prompt construction for debugging cache/context issues
# CACHE_TRACE=true

# ─── Fleet — multi-Claude orchestration (Phases d.1 → d.20) ────────────────
# See docs/fleet-guide.md for the full guide.

# API key required to authenticate WS clients to this peer's Gateway.
# Must have `fleet:listen` and/or `peer:invoke` scopes for cross-peer use.
# CODEBUDDY_FLEET_API_KEY=your_fleet_key_here

# Hostname broadcast in fleet:* events + peer.describe. Defaults to os.hostname().
# CODEBUDDY_FLEET_HOSTNAME=ministar

# Peer role taxonomy (Phase d.14). 'leaf' refuses outbound peer.invoke calls
# (service-only peers). 'orchestrator'/'main' accept both directions.
# CODEBUDDY_PEER_ROLE=main

# Maximum call-chain depth for peer.invoke. Default 3. Anti-recursion guard.
# CODEBUDDY_PEER_MAX_DEPTH=3

# Peer chat provider auto-detect override. When set, skips the env-priority
# detection and forces a specific provider. Values: ollama|grok|anthropic|
# gemini|openai. Default: auto-detect (Ollama first if OLLAMA_HOST set).
# CODEBUDDY_PEER_PROVIDER=ollama

# Override the model used by peer.chat for THIS peer (provider's default
# otherwise — e.g. qwen2.5-coder:7b for Ollama).
# CODEBUDDY_PEER_MODEL=qwen2.5-coder:32b

# peer_delegate per-turn cap (Phase d.17). After N delegate calls in a
# rolling 120s window, further calls return a cap error. Prevents runaway
# LLM-side delegation loops. Default 5.
# CODEBUDDY_PEER_DELEGATE_MAX_PER_TURN=5

# Opt-in fleet event broadcasting (Phase d.2). When set to '1', tool starts
# and completions are broadcast on the fleet bus for observability.
# CODEBUDDY_FLEET_STREAM=1

# ─── Server (Docker / VPS / self-host — `buddy server`) ────────────────────
# See docs/install.md and docs/deployment.md. Only needed to run the server;
# the CLI ignores these.

# JWT_SECRET is MANDATORY in production (NODE_ENV=production): the server
# refuses to start without it. Generate one with: openssl rand -hex 32
# JWT_SECRET=change_me_openssl_rand_hex_32

# Marks the process as production (enables the JWT requirement above).
# NODE_ENV=production

# Bind address / port for `buddy server`. HOST=0.0.0.0 exposes it to the
# network — front it with a reverse proxy + TLS. Loopback: HOST=127.0.0.1
# HOST=0.0.0.0
# PORT=3000

# Comma-separated allowed browser origins. Lock to your real client origins
# in production — never "*".
# CORS_ORIGINS=https://app.example.com