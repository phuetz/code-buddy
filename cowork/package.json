{
  "name": "@phuetz/codebuddy-cowork",
  "version": "1.0.0",
  "description": "Desktop Agent application with sandboxed environment for AI Agent interaction",
  "keywords": [
    "ai-agent",
    "claude",
    "electron",
    "desktop-app",
    "mcp",
    "sandbox",
    "open-source"
  ],
  "homepage": "https://github.com/OpenCoworkAI/open-cowork",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenCoworkAI/open-cowork.git"
  },
  "bugs": {
    "url": "https://github.com/OpenCoworkAI/open-cowork/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "npm run download:node && npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && vite",
    "dev:with-python": "npm run download:node && npm run prepare:python && npm run prepare:python:skills && npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && vite",
    "build": "npm run download:node && npm run prepare:gui-tools && npm run prepare:python:all && npm run prepare:python:skills && npm run build:wsl-agent && npm run build:lima-agent && npm run build:mcp && npm run build:tray-icon && tsc && vite build && node scripts/pre-build-check.js && electron-builder",
    "build:e2e": "vite build",
    "build:win": "node scripts/build-windows.js",
    "build:tray-icon": "node scripts/build-tray-icon.js",
    "build:wsl-agent": "tsc -p src/main/sandbox/wsl-agent/tsconfig.json",
    "build:lima-agent": "tsc -p src/main/sandbox/lima-agent/tsconfig.json",
    "build:mcp": "node scripts/bundle-mcp.js",
    "commitlint": "commitlint --config commitlint.config.cjs",
    "download:node": "node scripts/download-node.js",
    "postinstall": "node scripts/download-node.js && npm run rebuild",
    "prepare": "husky",
    "prepare:gui-tools": "node scripts/prepare-gui-tools.js",
    "prepare:python": "node scripts/prepare-python.js",
    "prepare:python:all": "node scripts/prepare-python.js --all",
    "prepare:python:skills": "node scripts/install-skill-python-deps.mjs",
    "prepare:python:extras": "node scripts/install-skill-python-extras.mjs",
    "preview": "vite preview",
    "lint": "node scripts/lint.cjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build:e2e && playwright test",
    "verify:maison-runtime": "node scripts/verify-maison-runtime.mjs",
    "bench": "vitest bench",
    "bench:api": "node scripts/bench-api.mjs",
    "rebuild": "node -e \"const {execSync}=require('node:child_process'); const v=require('electron/package.json').version; execSync('npm rebuild better-sqlite3 --runtime=electron --target='+v+' --disturl=https://electronjs.org/headers',{stdio:'inherit'})\"",
    "typecheck": "tsc --noEmit",
    "pre-build-check": "node scripts/pre-build-check.js",
    "clean": "rimraf dist dist-electron dist-mcp dist-wsl-agent dist-lima-agent .bundle-resources release",
    "deploy:local": "bash scripts/deploy-local.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/theme-one-dark": "6.1.3",
    "@larksuiteoapi/node-sdk": "^1.70.0",
    "@mariozechner/pi-ai": "^0.60.0",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ngrok/ngrok": "^1.7.0",
    "@uiw/react-codemirror": "4.25.10",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "@xyflow/react": "12.11.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.1",
    "dagre": "0.8.5",
    "dompurify": "3.4.11",
    "dotenv": "^17.2.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.0",
    "framer-motion": "12.40.0",
    "glob": "^10.3.10",
    "highlight.js": "^11.11.1",
    "i18next": "^25.10.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.468.0",
    "mermaid": "11.16.0",
    "onnxruntime-node": "^1.20.0",
    "openai": "^6.32.0",
    "rc-dock": "4.0.0-alpha.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.0",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "4.11.2",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@electron/notarize": "^2.5.0",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dagre": "0.7.54",
    "@types/dompurify": "3.0.5",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "4.1.0",
    "autoprefixer": "^10.4.27",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "16.4.0",
    "png-to-ico": "3.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.3.3",
    "vite": "^7.3.3",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "@protobufjs/utf8": "^1.1.2",
    "axios": "^1.18.1",
    "fast-uri": "^3.1.3",
    "fast-xml-builder": "^1.2.1",
    "fast-xml-parser": "^5.7.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.6",
    "hono": "^4.12.29",
    "ip-address": "^10.2.0",
    "js-yaml": "^4.3.0",
    "lodash": "^4.18.1",
    "path-to-regexp": "^8.4.2",
    "protobufjs": "^7.6.5",
    "qs": "^6.15.3",
    "tar": "^7.5.15",
    "undici": "^7.28.0",
    "vite": "^7.3.3",
    "ws": "^8.20.1",
    "yaml": "^2.9.0"
  },
  "author": "Code Buddy Cowork Team",
  "license": "MIT",
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
